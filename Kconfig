menu "Location sample"

config GOLIOTH_SAMPLE_PSK_ID
	string "Golioth PSK Identity"
	default ""
	help
	  PSK Identity used to authenticate with Golioth (e.g. device-id@project).
	  Set this in a local credentials.conf file, not in tracked source.

config GOLIOTH_SAMPLE_PSK
	string "Golioth PSK"
	default ""
	help
	  Pre-shared key used to authenticate with Golioth.
	  Set this in a local credentials.conf file, not in tracked source.

config GPS_SAMPLE_ANTENNA_ONBOARD
	bool "Enable onboard GNSS antenna power via COEX0"
	default n
	help
	  Send a modem AT command at startup to enable the onboard GNSS
	  antenna/LNA power path on boards that require COEX0 control.

config GPS_SAMPLE_AT_COEX0
	string "AT command used to enable onboard GNSS antenna"
	default "AT\%XCOEX0=1,1,1565,1586"
	help
	  AT command sent when GPS_SAMPLE_ANTENNA_ONBOARD is enabled.

config GPS_SAMPLE_AT_MAGPIO
	string "Optional AT%XMAGPIO command for GNSS RF path"
	default ""
	help
	  Optional board-specific AT command sent before COEX0 to configure
	  MAGPIO/RF routing for GNSS. Leave empty if not required.

config GPS_SAMPLE_AT_MIPIRFFEDEV
	string "Optional AT%XMIPIRFFEDEV command for GNSS RF path"
	default ""
	help
	  Optional board-specific AT command sent before COEX0 to configure
	  MIPI-RFFE device mapping. Leave empty if not required.

config GPS_SAMPLE_AT_MIPIRFFECTRL_INIT
	string "Optional AT%XMIPIRFFECTRL INIT command for GNSS RF path"
	default ""
	help
	  Optional board-specific AT command sent before COEX0 to set MIPI-RFFE
	  control for the INIT state. Leave empty if not required.

config GPS_SAMPLE_AT_MIPIRFFECTRL_ON
	string "Optional AT%XMIPIRFFECTRL ON command for GNSS RF path"
	default ""
	help
	  Optional board-specific AT command sent before COEX0 to set MIPI-RFFE
	  control for the ON state. Leave empty if not required.

config SOLAR_ENERGY_CLICK_MONITOR
	bool "Log Solar Energy 2 Click status GPIOs (BLV, HLV, WUP)"
	default n
	depends on GPIO
	help
	  MikroE Solar Energy 2 Click exposes battery/harvester level indicators and
	  wake on the mikroBUS AN (WUP), INT (HLV), and PWM (BLV) lines. When enabled,
	  the firmware samples those pins on nRF GPIO0 and logs levels periodically.

config SOLAR_ENERGY_CLICK_MONITOR_INTERVAL_SEC
	int "Seconds between Solar Energy Click GPIO log lines"
	depends on SOLAR_ENERGY_CLICK_MONITOR
	range 1 3600
	default 30

config SOLAR_ENERGY_CLICK_GPIO_BLV
	int "nRF GPIO0 pin for BLV (mikroBUS PWM)"
	depends on SOLAR_ENERGY_CLICK_MONITOR
	range 0 31
	default 30 if BOARD_CONEXIO_STRATUS_NRF9160 || BOARD_CONEXIO_STRATUS_NRF9160_NS
	default 3 if BOARD_CONEXIO_STRATUS_PRO_NRF9161 || BOARD_CONEXIO_STRATUS_PRO_NRF9161_NS
	default 30

config SOLAR_ENERGY_CLICK_GPIO_HLV
	int "nRF GPIO0 pin for HLV (mikroBUS INT)"
	depends on SOLAR_ENERGY_CLICK_MONITOR
	range 0 31
	default 29 if BOARD_CONEXIO_STRATUS_NRF9160 || BOARD_CONEXIO_STRATUS_NRF9160_NS
	default 2 if BOARD_CONEXIO_STRATUS_PRO_NRF9161 || BOARD_CONEXIO_STRATUS_PRO_NRF9161_NS
	default 29

config SOLAR_ENERGY_CLICK_GPIO_WUP
	int "nRF GPIO0 pin for WUP (mikroBUS AN)"
	depends on SOLAR_ENERGY_CLICK_MONITOR
	range 0 31
	default 13 if BOARD_CONEXIO_STRATUS_NRF9160 || BOARD_CONEXIO_STRATUS_NRF9160_NS
	default 13 if BOARD_CONEXIO_STRATUS_PRO_NRF9161 || BOARD_CONEXIO_STRATUS_PRO_NRF9161_NS
	default 13

endmenu

menu "Zephyr Kernel"
source "Kconfig.zephyr"
endmenu
