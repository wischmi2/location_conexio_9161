menu "Location sample"

config GOLIOTH_SAMPLE_PSK_ID
	string "Golioth PSK Identity"
	default ""
	help
	  PSK Identity used to authenticate with Golioth (e.g. device-id@project).
	  Set this in a local credentials.conf file, not in tracked source.

config GOLIOTH_SAMPLE_PSK
	string "Golioth PSK"
	default ""
	help
	  Pre-shared key used to authenticate with Golioth.
	  Set this in a local credentials.conf file, not in tracked source.

config GPS_SAMPLE_ANTENNA_ONBOARD
	bool "Enable onboard GNSS antenna power via COEX0"
	default n
	help
	  Send a modem AT command at startup to enable the onboard GNSS
	  antenna/LNA power path on boards that require COEX0 control.

config GPS_SAMPLE_AT_COEX0
	string "AT command used to enable onboard GNSS antenna"
	default "AT\%XCOEX0=1,1,1565,1586"
	help
	  AT command sent when GPS_SAMPLE_ANTENNA_ONBOARD is enabled.

endmenu

menu "Zephyr Kernel"
source "Kconfig.zephyr"
endmenu
