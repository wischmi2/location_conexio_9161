# Copy to credentials.conf (kept out of git) and set real values from the Golioth console.
# Build with: -DEXTRA_CONF_FILE="overlay-golioth.conf;credentials.conf"
#
# PSK is stored in the modem sec tag via AT%%CMNG (same baseline as master / stratus9161).
# - If the Golioth UI shows a 64- or 128-character hex secret, paste it in full: firmware
#   decodes to raw key bytes, then writes the correct hex form for the modem.
# - If you use a short ASCII passphrase in Kconfig, firmware uses the classic per-byte
#   hex expansion (master behavior).
#
CONFIG_GOLIOTH_SAMPLE_PSK_ID="your-device-id@your-project"
CONFIG_GOLIOTH_SAMPLE_PSK="your-psk-secret"
